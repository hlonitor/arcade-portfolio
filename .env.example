# ---------------------------------------------------------------------------
# EmailJS credentials for the in-game "Terminal" contact form.
#
# These are PUBLIC, client-side identifiers (safe to expose in a static site) —
# EmailJS is designed for browser use and rate-limits per-domain. They are NOT
# secret API keys. Never put a private/secret key in a Vite VITE_ var: anything
# prefixed VITE_ is inlined into the shipped bundle and is world-readable.
#
# Local dev:  copy this file to `.env` and fill in your values.
# Production: set these as GitHub Actions repository *variables* (or secrets),
#             which the deploy workflow injects at build time.
#
# Get them at https://dashboard.emailjs.com/  (Account -> API keys / Email Services)
# ---------------------------------------------------------------------------
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=

# Optional: override the LinkedIn URL shown in the HUD.
VITE_LINKEDIN_URL=https://linkedin.com
